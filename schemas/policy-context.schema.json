{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reht.dev/schemas/0.1/policy-context.schema.json",
  "title": "REHT Policy Context",
  "type": "object",
  "additionalProperties": false,
  "required": ["policy_set_id", "version", "effective_at", "rules"],
  "properties": {
    "policy_set_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "effective_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "jurisdiction": {"type": "array", "items": {"type": "string"}},
    "rules": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["rule_id", "effect"], "properties": {"rule_id": {"type": "string"}, "effect": {"type": "string", "enum": ["PERMIT", "PROHIBIT", "REQUIRE", "ESCALATE"]}, "condition_ref": {"type": "string"}}, "additionalProperties": false}
  }
}
