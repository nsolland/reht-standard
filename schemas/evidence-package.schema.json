{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reht.dev/schemas/0.1/evidence-package.schema.json",
  "title": "REHT Evidence Package",
  "type": "object",
  "additionalProperties": false,
  "required": ["package_id", "created_at", "items"],
  "properties": {
    "package_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "source", "observed_at", "integrity"],
        "properties": {
          "evidence_id": {"type": "string"},
          "source": {"type": "string"},
          "observed_at": {"type": "string", "format": "date-time"},
          "expires_at": {"type": "string", "format": "date-time"},
          "content_ref": {"type": "string"},
          "integrity": {"type": "object", "required": ["algorithm", "digest"], "properties": {"algorithm": {"type": "string"}, "digest": {"type": "string"}}, "additionalProperties": false}
        }
      }
    }
  }
}
