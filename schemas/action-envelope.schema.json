{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reht.dev/schemas/0.1/action-envelope.schema.json",
  "title": "REHT Action Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "action_id",
    "timestamp",
    "actor",
    "action_type",
    "target",
    "authority",
    "evidence_refs",
    "policy_refs",
    "governance_state"
  ],
  "properties": {
    "spec_version": {"type": "string", "const": "0.1.0-draft"},
    "action_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "type": {"type": "string", "enum": ["HUMAN", "AGENT", "SERVICE", "SYSTEM"]}
      }
    },
    "action_type": {"type": "string", "minLength": 1},
    "target": {"type": "string", "minLength": 1},
    "authority": {
      "type": "object",
      "additionalProperties": true,
      "required": ["scope"],
      "properties": {
        "scope": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "delegation_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "policy_refs": {"type": "array", "items": {"type": "string"}},
    "governance_state": {"type": "string", "enum": ["NORMAL", "SAFE", "HALT"]},
    "context": {"type": "object", "additionalProperties": true}
  }
}